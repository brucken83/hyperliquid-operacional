<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Hyperliquid Dashboard v3.1</title>
  <link rel="stylesheet" href="./style.css">
</head>
<body>
  <div class="container">
    <header class="hero">
      <div><h1>Hyperliquid Dashboard</h1><p class="subtitle">Scanner GitHub + Telegram + Paper Trade</p></div>
      <div class="pill" id="last-update">Última atualização: --</div>
    </header>
    <section class="metrics" id="metrics"></section>
    <section><h2>Status</h2><div id="status" class="grid"></div></section>
    <section><h2>Market Metrics</h2><div id="market-metrics" class="grid"></div></section>
    <section><h2>Sinais</h2><div id="signals"></div></section>
    <section><h2>Histórico de sinais</h2><div id="history"></div></section>
    <section><h2>Paper Trades</h2><div id="paper"></div></section>
  </div>
  <script src="./app.js"></script>
</body>
</html>
