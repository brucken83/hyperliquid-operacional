async function loadJson(path){const r=await fetch(path+`?v=${Date.now()}`);return await r.json()}function card(html,extra=''){return `<div class="card ${extra}">${html}</div>`}function metric(label,value){return `<div class="metric-card"><div class="metric-label">${label}</div><div class="metric-value">${value}</div></div>`}function fundingClass(v){return Number(v)>=0?'funding-pos':'funding-neg'}function cvdClass(v){return Number(v)>=0?'cvd-pos':'cvd-neg'}function fmt(v,d=2){if(v===null||v===undefined||v==='')return '--';return Number(v).toFixed(d)}function fmtDate(s){if(!s)return '--';const d=new Date(s);if(isNaN(d))return s;return d.toLocaleString('pt-BR',{dateStyle:'short',timeStyle:'short'})}async function main(){const status=await loadJson('./data/latest_status.json');const signals=await loadJson('./data/signals.json');const history=await loadJson('./data/signals_history.json');const paper=await loadJson('./data/paper_trades.json');const meta=await loadJson('./data/meta.json');const market=await loadJson('./data/market_metrics.json');document.getElementById('last-update').textContent=`Última atualização: ${fmtDate(meta.last_update)}`;document.getElementById('metrics').innerHTML=metric('Ativos monitorados',meta.tracked_assets??0)+metric('Sinais agora',meta.signals_now??0)+metric('Bull',meta.bull_count??0)+metric('Bear',meta.bear_count??0);document.getElementById('status').innerHTML=status.length?status.map(s=>card(`<div><strong style="font-size:24px;">${s.coin}</strong><span class="badge ${s.trend==='bull'?'bull':'bear'}">${s.trend}</span></div><div class="row">Preço: <strong>${fmt(s.price)}</strong></div><div class="row">Funding: <span class="${fundingClass(s.funding_hr_pct)}">${fmt(s.funding_hr_pct,4)}%/h</span></div><div class="row">RSI2: <strong>${fmt(s.rsi2)}</strong></div><div class="row dim"><small>${fmtDate(s.time)}</small></div>`)).join(''):`<div class="empty">Sem status.</div>`;const mm=Object.entries(market||{});document.getElementById('market-metrics').innerHTML=mm.length?mm.map(([coin,m])=>card(`<div><strong style="font-size:24px;">${coin}</strong></div><div class="row">Funding Rate: <span class="${fundingClass(m.funding_hr_pct)}">${fmt(m.funding_hr_pct,4)}%/h</span></div><div class="row">OI: <span class="oi">${m.open_interest===null||m.open_interest===undefined?'--':fmt(m.open_interest,2)}</span></div><div class="row">CVD total: <span class="${cvdClass(m.cvd_total)}">${fmt(m.cvd_total,2)}</span></div><div class="row">CVD 12 candles: <span class="${cvdClass(m.cvd_12bars)}">${fmt(m.cvd_12bars,2)}</span></div><div class="row">Long/Short Ratio: <span class="ratio-high">${m.long_short_ratio===null||m.long_short_ratio===undefined?'--':fmt(m.long_short_ratio,3)}</span></div>`)).join(''):`<div class="empty">Sem market metrics.</div>`;document.getElementById('signals').innerHTML=signals.length?`<div class="grid">`+signals.map(s=>{const riskPct=Math.abs((Number(s.entry)-Number(s.stop))/Number(s.entry))*100;return card(`<div><strong style="font-size:22px;">${s.coin}</strong><span class="badge ${s.side==='LONG'?'long':'short'}">${s.side}</span></div><div class="row">Entrada: <strong>${fmt(s.entry)}</strong></div><div class="row">Stop: <strong>${fmt(s.stop)}</strong></div><div class="row signal-risk">Risco: ${fmt(riskPct,2)}%</div><div class="row">T1: <strong>${fmt(s.target1)}</strong></div><div class="row">T2: <strong>${fmt(s.target2)}</strong></div><div class="row">Funding: <span class="${fundingClass(s.funding_hr_pct)}">${fmt(s.funding_hr_pct,4)}%/h</span></div><div class="row dim"><small>${fmtDate(s.time)}</small></div>`,'signal-strong')}).join('')+`</div>`:`<div class="empty">Sem sinais no momento.</div>`;document.getElementById('history').innerHTML=history.length?`<div class="grid">`+history.map(s=>card(`<div><strong>${s.coin}</strong><span class="badge ${s.side==='LONG'?'long':'short'}">${s.side}</span></div><div class="row">Entrada: ${fmt(s.entry)}</div><div class="row">Stop: ${fmt(s.stop)}</div><div class="row">T1: ${fmt(s.target1)}</div><div class="row">T2: ${fmt(s.target2)}</div><div class="row dim"><small>${fmtDate(s.time)}</small></div>`)).join('')+`</div>`:`<div class="empty">Sem histórico ainda.</div>`;document.getElementById('paper').innerHTML=paper.length?`<div class="grid">`+paper.map(p=>card(`<div><strong>${p.coin}</strong><span class="badge ${p.side==='LONG'?'long':'short'}">${p.side}</span></div><div class="row">Entrada: ${fmt(p.entry)}</div><div class="row">Stop: ${fmt(p.stop)}</div><div class="row">Status: <strong>${p.status}</strong></div><div class="row dim"><small>${fmtDate(p.time)}</small></div>`)).join('')+`</div>`:`<div class="empty">Sem paper trades.</div>`}main();